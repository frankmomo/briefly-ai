# =====================================
# BRIEFLY AI — ENVIRONMENT CONFIG
# =====================================
# Copia este archivo como .env y llena tus credenciales

# --- Google OAuth ---
GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_client_secret
# URI de redirección OAuth (configurada en Google Cloud Console)
# Debe apuntar al callback del frontend en Vercel.
# Ejemplo: https://tu-app.vercel.app/callback
GOOGLE_REDIRECT_URI=https://tu-app.vercel.app/callback

# --- OpenAI ---
OPENAI_API_KEY=sk-tu_api_key_openai

# --- Supabase ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_supabase_anon_key
SUPABASE_SERVICE_KEY=tu_supabase_service_role_key

# --- Redis (Upstash o local) ---
REDIS_URL=redis://localhost:6379
# Para Upstash (serverless Redis):
# REDIS_URL=rediss://default:password@us1-available-reindeer-12345.upstash.io:6379

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_tu_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_tu_monthly_price_id
STRIPE_PRICE_ID_YEARLY=price_tu_yearly_price_id

# --- Session / JWT ---
JWT_SECRET=genera_un_hash_seguro_de_64_caracteres
SESSION_TTL_DAYS=30

# --- App ---
PORT=3001
NODE_ENV=production
APP_URL=https://tu-app.vercel.app
